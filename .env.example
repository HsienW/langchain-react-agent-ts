# LangChain Agent 環境變數
# 請複製此檔案為 .env，並填入你的 API key。

# ============================================
# 模型供應商 API Key（至少需要一組）
# ============================================

# Anthropic API Key（Claude 模型）
# 取得位置：https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key（GPT 模型）
# 取得位置：https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# 可選：LangSmith 追蹤與除錯
# ============================================

# 開發階段建議啟用 LangSmith tracing。
# 註冊位置：https://smith.langchain.com/
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=simple-react-agent-ts

# ============================================
# 可選：其他工具 API Key
# ============================================

# Tavily API Key（可用於網路搜尋工具）
# 取得位置：https://app.tavily.com/
# TAVILY_API_KEY=your-tavily-api-key-here
